# Deploy-host configuration. Copy to deploy.env and fill in values.
# Sourced over SSH by the PREVIEW scripts (scripts/deploy-preview.sh,
# scripts/teardown-preview.sh). Never commit deploy.env — it may contain secrets.
#
# Prod web no longer uses this file. It runs from the root compose.yaml, which
# works out of the box with no host config (see that file's header for the
# optional WEB_IMAGE / IMAGE_TAG / PROXY_NETWORK overrides). Routing for both
# suro.clotet.dev and suroapp.cat is configured once in Pangolin — see AGENTS.md.

# Shared Docker / Traefik
# Dedicated network shared with Traefik. Create it once and connect gerbil to it so
# Traefik (which shares gerbil's network namespace) can reach the containers by name:
#   docker network create familia-previews
#   docker network connect familia-previews gerbil
export PREVIEW_DOCKER_NETWORK=familia-previews
# Directory watched by Traefik's file provider — one .yml per preview is written here.
# See AGENTS.md for the one-time server setup required to enable this.
export TRAEFIK_ROUTES_DIR=/srv/pangolin/config/traefik/routes

# Preview environments
export PREVIEW_WORKDIR=/srv/familia/previews   # parent dir for per-MR compose files
export PREVIEW_DOMAIN=suro.clotet.dev
export PREVIEW_ENV_FILE=/srv/familia/preview.env
