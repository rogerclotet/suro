{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "PATH=/usr/bin:$PATH expo run:ios",
    "web": "expo start --web",
    "build:android:preview": "mkdir -p build && eas build --platform android --profile preview --local --output build/suro-preview.apk",
    "build:android:prod-apk": "mkdir -p build && eas build --platform android --profile production-apk --local --output build/suro-prod.apk",
    "build:android:release": "mkdir -p build && eas build --platform android --profile production --local --output build/suro-release.aab",
    "build:ios:release": "mkdir -p build && PATH=/usr/bin:$PATH eas build --platform ios --profile production --local --output build/suro-release.ipa",
    "submit:android:release": "eas submit -p android --profile production --path build/suro-release.aab --non-interactive",
    "release:android": "pnpm run build:android:release && pnpm run submit:android:release",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@10play/tentap-editor": "^1.0.1",
    "@convex-dev/auth": "^0.0.93",
    "@expo-google-fonts/convergence": "^0.4.1",
    "@formatjs/intl-pluralrules": "^6.3.9",
    "backend": "workspace:*",
    "convex": "^1.40.0",
    "expo": "~56.0.8",
    "expo-auth-session": "~56.0.5",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.16",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "^56.0.20",
    "expo-device": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-image-picker": "~56.0.15",
    "expo-linking": "~56.0.13",
    "expo-notifications": "~56.0.15",
    "expo-router": "~56.2.8",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.16",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "lucide-react-native": "^1.17.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-paper": "^5.15.3",
    "react-native-reanimated": "4.3.1",
    "react-native-reanimated-dnd": "^2.0.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "use-intl": "^4.11.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@types/react": "~19.2.2",
    "eas-cli": "^20.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~56.0.4",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  }
}
