{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:dev": "APP_VARIANT=dev expo run:android",
    "ios": "node scripts/run-ios-simulator.mjs",
    "ios:rebuild": "rm -rf ios android .expo && node scripts/run-ios-simulator.mjs",
    "web": "expo start --web",
    "build:android:preview": "mkdir -p build && eas build --platform android --profile preview --local --output build/suro-preview.apk",
    "build:android:dev": "mkdir -p build && eas build --platform android --profile dev --local --output build/suro-dev.apk",
    "build:android:prod-apk": "mkdir -p build && eas build --platform android --profile production-apk --local --output build/suro-prod.apk",
    "build:android:release": "mkdir -p build && eas build --platform android --profile production --local --output build/suro-release.aab",
    "build:ios:release": "mkdir -p build && PATH=/usr/bin:$PATH eas build --platform ios --profile production --local --output build/suro-release.ipa",
    "presubmit:android:release": "pnpm -w changelog:generate",
    "submit:android:release": "bundle exec fastlane android release",
    "submit:android:metadata": "bundle exec fastlane android metadata",
    "submit:android:promote": "bundle exec fastlane android promote",
    "release:android": "pnpm run build:android:release && pnpm run submit:android:release",
    "submit:ios:beta": "bundle exec fastlane ios beta",
    "presubmit:ios:metadata": "pnpm -w changelog:generate",
    "submit:ios:metadata": "eas metadata:push --profile production",
    "submit:ios:release": "bundle exec fastlane ios release",
    "release:ios": "pnpm run build:ios:release && pnpm run submit:ios:release && pnpm run submit:ios:metadata",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@10play/tentap-editor": "^1.0.1",
    "@convex-dev/auth": "^0.0.94",
    "@expo-google-fonts/convergence": "^0.4.1",
    "@expo/dom-webview": "~57.0.0",
    "@expo/log-box": "~57.0.0",
    "@expo/metro-runtime": "~57.0.3",
    "@floating-ui/dom": "^1.8.0",
    "@formatjs/intl-pluralrules": "^6.3.12",
    "backend": "workspace:*",
    "convex": "^1.42.1",
    "expo": "~57.0.4",
    "expo-apple-authentication": "~57.0.0",
    "expo-application": "~57.0.0",
    "expo-auth-session": "~57.0.2",
    "expo-clipboard": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-crypto": "~57.0.0",
    "expo-dev-client": "^57.0.5",
    "expo-device": "~57.0.0",
    "expo-document-picker": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-image-picker": "~57.0.2",
    "expo-linking": "~57.0.2",
    "expo-localization": "~57.0.0",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-secure-store": "~57.0.0",
    "expo-sharing": "~57.0.3",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "lucide-react-native": "^1.24.0",
    "posthog-react-native": "^4.56.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-android-widget": "^0.21.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-mmkv": "^4.3.2",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-paper": "^5.15.3",
    "react-native-reanimated": "4.5.1",
    "react-native-reanimated-dnd": "^2.0.0",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "4.26.0",
    "react-native-svg": "15.15.5",
    "react-native-web": "~0.21.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.10.2",
    "use-intl": "^4.13.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@react-native/metro-config": "0.86.0",
    "@types/react": "19.2.17",
    "eas-cli": "^20.5.1",
    "eslint": "^9.39.5",
    "eslint-config-expo": "~57.0.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  }
}
