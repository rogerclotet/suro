{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "PATH=/usr/bin:$PATH LOCAL_IOS_SIM_BUILD=1 expo run:ios",
    "web": "expo start --web",
    "build:android:preview": "mkdir -p build && eas build --platform android --profile preview --local --output build/suro-preview.apk",
    "build:android:prod-apk": "mkdir -p build && eas build --platform android --profile production-apk --local --output build/suro-prod.apk",
    "build:android:release": "mkdir -p build && eas build --platform android --profile production --local --output build/suro-release.aab",
    "build:ios:release": "mkdir -p build && PATH=/usr/bin:$PATH eas build --platform ios --profile production --local --output build/suro-release.ipa",
    "submit:android:release": "bundle exec fastlane android release",
    "submit:android:metadata": "bundle exec fastlane android metadata",
    "submit:android:promote": "bundle exec fastlane android promote",
    "release:android": "pnpm run build:android:release && pnpm run submit:android:release",
    "submit:ios:beta": "bundle exec fastlane ios beta",
    "submit:ios:metadata": "eas metadata:push --profile production",
    "submit:ios:release": "bundle exec fastlane ios release",
    "release:ios": "pnpm run build:ios:release && pnpm run submit:ios:release",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@10play/tentap-editor": "^1.0.1",
    "@convex-dev/auth": "^0.0.94",
    "@expo-google-fonts/convergence": "^0.4.1",
    "@formatjs/intl-pluralrules": "^6.3.10",
    "backend": "workspace:*",
    "convex": "^1.41.0",
    "expo": "~56.0.12",
    "expo-apple-authentication": "~56.0.4",
    "expo-application": "~56.0.3",
    "expo-auth-session": "~56.0.14",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "^56.0.20",
    "expo-device": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-image-picker": "~56.0.18",
    "expo-linking": "~56.0.14",
    "expo-localization": "~56.0.6",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.18",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "lucide-react-native": "^1.21.0",
    "posthog-react-native": "^4.50.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-paper": "^5.15.3",
    "react-native-reanimated": "4.3.1",
    "react-native-reanimated-dnd": "^2.0.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "use-intl": "^4.13.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@types/react": "19.2.17",
    "eas-cli": "^20.3.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~56.0.4",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  }
}
