# Convex deployment URL (from `npx convex dev` in packages/backend, or your prod
# deployment). Inlined into the client bundle at build time.
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Production web app origin, used to build shareable links to events/lists.
# Falls back to https://suro.clotet.dev when unset.
EXPO_PUBLIC_SITE_URL=https://suro.clotet.dev

# PostHog product analytics + error tracking (project 28027, EU). Use the same
# client token the web app uses (NEXT_PUBLIC_POSTHOG_KEY). Leave the key empty
# to disable analytics locally. Inlined into the client bundle at build time;
# native EAS builds get the key from an EAS environment variable, not here.
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
